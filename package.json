{
  "name": "quicksearch-browser-extension",
  "version": "1.0.0",
  "description": "QuickSearch - Modern Vue.js browser extension with chat, knowledge base, and search functionality",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --open /src/entries/web.html",
    "dev:simple": "vite --open /web-simple.html",
    "build": "vite build",
    "build:web": "vite build --mode web",
    "preview": "vite preview",
    "preview:web": "vite preview --open /web.html",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vite --open /test-page.html",
    "lint": "eslint src --ext .js,.vue",
    "format": "prettier --write src/**/*.{js,vue,css}"
  },
  "dependencies": {
    "bootstrap-icons": "^1.13.1",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.5.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^8.55.0",
    "eslint-plugin-vue": "^9.19.0",
    "jsdom": "^23.0.0",
    "prettier": "^3.1.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "vue",
    "browser-extension",
    "vite",
    "chat",
    "knowledge-base"
  ],
  "author": "",
  "license": "MIT"
}
